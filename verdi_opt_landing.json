                      "id":  "schedule-trigger-opt",
                      "name":  "Schedule Trigger",
                      "type":  "n8n-nodes-base.scheduleTrigger",
                      "position":  [160, 80],
                      "typeVersion":  1.2
                  },
                  {
                      "parameters":  {
                                         "projectId":  "meli-bi-data",
                                         "sqlQuery":  "-- ============================================================\n-- OPTIMIZACIÓN DE LANDING — Splinter Component Performance\n-- Fechas: 2026-04-20 \u2192 2026-05-05\n-- Landings: ofertas futboleras, 5 5 descuentos parcial\n-- Para nueva campaña: actualizar LANDING_NAME IN y fechas\n-- ============================================================\n\nSELECT TO_BASE64(CAST(\n  CONCAT(\n    \u0027{\"opt_landing\":\u0027,\n    (SELECT TO_JSON_STRING(ARRAY_AGG(STRUCT(\n      date, landing_name, button_name, prints, clicks, transactions, si, tgmv, sessions\n    ) ORDER BY date, landing_name)) FROM (\n      SELECT\n        DATE_EVENT                                  AS date,\n        LANDING_NAME                                AS landing_name,\n        CAMPAIGN_NAME                               AS button_name,\n        SUM(COALESCE(TOTAL_PRINTS, 0))              AS prints,\n        SUM(COALESCE(TOTAL_CLICKS, 0))              AS clicks,\n        SUM(COALESCE(TOTAL_TRANSACTION_24HS, 0))    AS transactions,\n        SUM(COALESCE(TOTAL_SI_24HS, 0))             AS si,\n        SUM(COALESCE(TOTAL_TGMV_24HS, 0))           AS tgmv,\n        SUM(COALESCE(TOTAL_SESSIONS_PRINT, 0))      AS sessions\n      FROM `meli-bi-data.WHOWNER.DM_SPLINTER_COMPONENT`\n      WHERE site_id = \u0027MLA\u0027\n        AND LANDING_NAME IN (\u0027hot-sale\u0027, \u0027hot sale parcial\u0027, \u0027hot-sale-tab\u0027)\n        AND DATE_EVENT BETWEEN \u00272026-05-11\u0027 AND \u00272026-05-18\u0027\n      GROUP BY 1, 2, 3\n    )),\n    \u0027,\"refreshed_at\":\"\u0027,\n    FORMAT_TIMESTAMP(\u0027%Y-%m-%dT%H:%M:%S\u0027, CURRENT_TIMESTAMP(), \u0027America/Argentina/Buenos_Aires\u0027),\n    \u0027\"}\u0027\n  )\nAS BYTES)) AS data_b64",
                                         "options":  {
                                                         "location":  "US"
                                                     }
                                     },
                      "id":  "bq-opt-landing",
                      "name":  "BQ Opt Landing",
                      "type":  "n8n-nodes-base.googleBigQuery",
                      "position":  [340, 80],
